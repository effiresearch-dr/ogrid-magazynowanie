@import "tailwindcss";

@theme {
  --font-sans: "Inter", ui-sans-serif, system-ui, sans-serif;
  
  --color-primary: var(--primary-color, #001F3F);
  --color-accent: var(--accent-color, #2563EB);
  --color-success: #16A34A;
  --color-background: #F8FAFC;
  --color-sidebar: #001F3F;
  --color-card: #FFFFFF;
}

:root {
  --primary-color: #001F3F;
  --accent-color: #2563EB;
  --logo-url: url('https://ais-dev-22wtstsgcwx7csvsjbjj65-4399042101.europe-west1.run.app/logo.png');
}

@layer base {
  body {
    @apply bg-background text-slate-900 font-sans antialiased;
  }
}

/* Custom scrollbar for data-dense tables */
::-webkit-scrollbar {
  width: 6px;
  height: 6px;
}

::-webkit-scrollbar-track {
  @apply bg-transparent;
}

::-webkit-scrollbar-thumb {
  @apply bg-slate-300 rounded-full;
}

::-webkit-scrollbar-thumb:hover {
  @apply bg-slate-400;
}

.terminal-window {
  @apply bg-black text-green-400 font-mono p-4 rounded-lg shadow-inner overflow-y-auto;
  height: 200px;
}

.card-container {
  @apply bg-white rounded-2xl shadow-sm border border-slate-100 p-6;
}

.data-table {
  @apply w-full text-sm text-left;
}

.data-table th {
  @apply px-4 py-3 bg-slate-50 text-slate-500 font-medium uppercase tracking-wider text-xs border-b border-slate-100;
}

.data-table td {
  @apply px-4 py-3 border-b border-slate-50 text-slate-700;
}

.step-active {
  @apply border-accent text-accent;
}

.step-inactive {
  @apply border-slate-200 text-slate-400;
}
